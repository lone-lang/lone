#!/usr/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later

# Validate that every test attribute file lives in a leaf directory.
# Test discovery treats a leaf directory -- one with no subdirectories
# -- as a test case, so an attribute in a non-leaf directory would never
# run. Flag any non-leaf directory, which is precisely a directory that
# is the parent of another directory, that holds an attribute file.

suite="${LONE_TEST_SUITE}"

violations=()
while IFS= read -r -d '' dir; do
  for attribute in input output error status arguments environment program-name script; do
    if [[ -f "${dir}/${attribute}" ]]; then
      violations+=("${dir}")
      break
    fi
  done
done < <(find "${suite}" -mindepth 1 -type d -printf '%h\0' | sort -zu)

if (( ${#violations[@]} > 0 )); then
  >&2 printf 'Non-leaf test directories detected:\n'
  >&2 printf '  %s\n' "${violations[@]}"
  exit 1
fi
